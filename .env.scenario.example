# .env.scenario — scenario-first-goal 등에서 참조하는 환경변수
# NOTE: 이 파일은 gitignore. 비밀값은 안 넣지만 프로젝트별 튜닝.

# === goal 4단계 — cost & iteration 제어 ===

# 1회 goal 실행 비용 상한 (USD). 초과 시 STUCK 으로 escalate.
# 0 = 무한 (명시 동의 없이 금지).
SCENARIO_GOAL_BUDGET=5

# 같은 시나리오 ID가 M회 연속 실패하면 STUCK.
SCENARIO_GOAL_STUCK_RETRIES=3

# 누적 iteration N회 초과하면 STUCK.
SCENARIO_GOAL_MAX_ITERATIONS=10

# === E2E 프레임워크 ===

# init이 결정한 프레임워크 이름 (참조용 — 실행 명령은 package.json/pyproject.toml에서)
SCENARIO_E2E_FRAMEWORK={{E2E_FRAMEWORK}}

# E2E 테스트 실행 명령 (goal이 게이트로 호출, ./init.sh verify 도 이걸 사용)
SCENARIO_E2E_CMD="{{E2E_TEST_CMD}}"

# 앱 실행 명령 (./init.sh start 가 사용 — review 4단계에서 본인이 직접 사용)
SCENARIO_START_CMD="npm run dev"

# === LLM judge fallback ===

# judge에 사용할 모델 (기본: 현재 세션 모델)
# SCENARIO_JUDGE_MODEL=claude-sonnet-4-6

# UNCERTAIN 판정을 STUCK으로 올릴지 (true 권장)
SCENARIO_JUDGE_UNCERTAIN_AS_STUCK=true
